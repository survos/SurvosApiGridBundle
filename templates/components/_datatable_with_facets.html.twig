<div {{ apiCall ? stimulus_controller(this.stimulusController, {
    schema: schema,
    globals: this.globals,
    api_call:  apiCall,
  #  searchBuilderColumns: this.searchBuilderColumns,
    locale: locale,
    globals: globals,
    buttons: buttons|default([]),

# arguably combined
    columnConfiguration: columns|json_encode,
    facetConfiguration: this.facetColumns|json_encode,
    searchBuilderFields: searchBuilderFields|json_encode,


    modalTemplate: this.modalTemplate,
    layout: this.layout|default(null),
    style: this.style,
    pageLength: this.pageLength,
    filter: this.filter,

    columnControl: this.columnControl,
    searchBuilder: this.searchBuilder,

    select: this.select,
    bulkActions: this.bulkActions|json_encode,
    entityClass: this.entityClass ?? '',
    csrfToken: this.select and this.bulkActions ? csrf_token(this.csrfTokenId) : '',
    defaultOrder: this.defaultOrder ?? '',
    showRoute: this.getShowRoute ?? '',
}) }}>

    <div class="card">
        <div class="card-body">
            <div {{ stimulus_target(this.stimulusController, 'message') }}></div>
            <div class="table-responsive customTable">
                <table class="table table-bordered table-striped" {{ stimulus_target(this.stimulusController, 'table') }}></table>
            </div>
        </div>
    </div>

    {% block modal %}
        {{ include('@SurvosApiGrid/_modal.html.twig', {
            formUrl: '/',
            aaController: this.stimulusController,
            modalController: 'modal-form',
            modalClass: 'modal-md',
            modalTitle: this.caller,
            buttonLabel: 'Show MODAL',
            modalContent: 'really should load with ajax'
        }) }}
    {% endblock %}

    {% if this.getShowRoute %}
    <div class="offcanvas offcanvas-end" tabindex="-1" style="width: min(600px, 90vw)"
         {{ stimulus_target(this.stimulusController, 'offcanvas') }}>
        <div class="offcanvas-header">
            <h5 class="offcanvas-title" {{ stimulus_target(this.stimulusController, 'offcanvasTitle') }}></h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body" {{ stimulus_target(this.stimulusController, 'offcanvasBody') }}></div>
    </div>
    {% endif %}

</div>
